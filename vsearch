#!/home/rtm/wrk/projects/obsidian-mcp/.venv/bin/python
"""Search the Obsidian vaults from the shell.

  vsearch how do I view the headless screen
  vsearch --semantic novel about Oxford translators
  vsearch --keyword IRMAA
  vsearch -k 20 --folder writing/nihongoism kata
  vsearch --status
  vsearch --reindex

Hybrid (keyword + semantic) is the default. Quotes around the query are
optional—bare words are joined.
"""

import argparse
import sys
import textwrap

import vault_index as vi


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="vsearch", description="Search Bob's Obsidian vaults.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent(__doc__.split("\n", 2)[2]),
    )
    ap.add_argument("query", nargs="*", help="what to search for")
    mode = ap.add_mutually_exclusive_group()
    mode.add_argument("--semantic", action="store_true", help="meaning only")
    mode.add_argument("--keyword", action="store_true", help="exact words only")
    ap.add_argument("-k", type=int, default=8, help="number of results (default 8)")
    ap.add_argument("--vault", help="vault name (default: the default vault)")
    ap.add_argument("--all", action="store_true", help="search every vault")
    ap.add_argument("--folder", help="restrict to a vault-relative folder")
    ap.add_argument("--full", action="store_true", help="print whole chunks")
    ap.add_argument("--paths", action="store_true", help="print paths only")
    ap.add_argument("--status", action="store_true", help="show index status and exit")
    ap.add_argument("--reindex", action="store_true", help="refresh the index and exit")
    args = ap.parse_args()

    if args.status:
        db = vi.connect()
        try:
            rows = db.execute(
                "SELECT vault, COUNT(*) FROM chunks GROUP BY vault").fetchall()
        finally:
            db.close()
        for name, path in sorted(vi.vaults().items()):
            n = dict(rows).get(name, 0)
            mark = "*" if name == vi.default_vault() else " "
            print(f"{mark} {name}: {n} chunks  ({path})")
        size = vi.DB_PATH.stat().st_size / 1e6 if vi.DB_PATH.exists() else 0
        print(f"\nindex {size:.1f} MB at {vi.DB_PATH}\nmodel {vi.MODEL} via {vi.OLLAMA}")
        return 0

    if args.reindex:
        scope = None if args.all else (args.vault or None)
        try:
            s = vi.reindex(vault=scope)
        except Exception as e:  # noqa: BLE001 — CLI: report, don't traceback
            print(f"reindex failed: {e}", file=sys.stderr)
            return 1
        print(f"{s['files_changed']} changed, {s['files_removed']} removed, "
              f"{s['chunks_total']} chunks total")
        return 0

    if not args.query:
        ap.print_help()
        return 2

    query = " ".join(args.query)
    scope = None if args.all else vi.resolve(args.vault)[0]
    fn = vi.semantic if args.semantic else vi.keyword if args.keyword else vi.hybrid
    try:
        hits = fn(query, args.k, scope, args.folder)
    except RuntimeError as e:  # Ollama unreachable
        print(e, file=sys.stderr)
        return 1

    if not hits:
        print("No matches.")
        return 1

    multi = len({h["vault"] for h in hits}) > 1
    for i, h in enumerate(hits, 1):
        loc = f"{h['vault']}:{h['path']}" if multi else h["path"]
        if args.paths:
            print(loc)
            continue
        print(f"\033[1m[{i}] {loc}\033[0m  ({h['score']})")
        print(f"    \033[2m{h['heading']}\033[0m")
        body = h["text"].split("\n\n", 1)[-1]
        if not args.full:
            body = textwrap.shorten(body.replace("\n", " "), 300, placeholder="…")
            print(f"    {body}")
        else:
            print(textwrap.indent(body, "    "))
        print()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
